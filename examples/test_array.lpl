include <console.lph>;

void main() {
    owner int[] arr = new int[5];

    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    arr[3] = 40;
    arr[4] = 50;

    int sum = arr[0] + arr[1] + arr[2] + arr[3] + arr[4];
    Console.printInt(sum);
    Console.println("");

    long len = arr.length;
    Console.printInt(len as int);
    Console.println("");
}
