{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LPL",
  "scopeName": "source.lpl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#include-directive" },
    { "include": "#annotations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#storage" },
    { "include": "#operators" },
    { "include": "#function-call" },
    { "include": "#class-declaration" },
    { "include": "#interface-declaration" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.lpl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.lpl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lpl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.lpl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.lpl",
          "match": "'(\\\\.|[^'])'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.lpl",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.lpl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "include-directive": {
      "patterns": [
        {
          "match": "^\\s*(include)\\s+(<[^>]+>|\"[^\"]+\")",
          "captures": {
            "1": { "name": "keyword.control.include.lpl" },
            "2": { "name": "string.quoted.other.include.lpl" }
          }
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.lpl",
          "match": "@(os|arch)\\([^)]*\\)",
          "captures": {
            "0": { "name": "entity.name.function.decorator.lpl" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lpl",
          "match": "\\b(if|else|while|for|do|switch|case|default|return|break|continue|fallthrough|try|catch|throw|finally|defer)\\b"
        },
        {
          "name": "keyword.operator.lpl",
          "match": "\\b(new|delete|move|as)\\b"
        },
        {
          "name": "keyword.other.lpl",
          "match": "\\b(include|namespace|extern|override|abstract|operator)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.lpl",
          "match": "\\b(void|bool|byte|char|short|int|long|float|double|string|auto)\\b"
        },
        {
          "name": "storage.type.class.lpl",
          "match": "\\b(class|interface)\\b"
        },
        {
          "name": "keyword.other.inheritance.lpl",
          "match": "\\b(extends|implements)\\b"
        },
        {
          "name": "storage.type.func.lpl",
          "match": "\\b(func)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.lpl",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.modifier.lpl",
          "match": "\\b(public|protected|private|static|const|owner)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.lpl",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.lpl",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.lpl",
          "match": "(\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.lpl",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.bitwise.lpl",
          "match": "(<<|>>|&|\\||\\^|~)"
        },
        {
          "name": "keyword.operator.range.lpl",
          "match": "(\\.\\.\\.=|\\.\\.\\.)"
        },
        {
          "name": "keyword.operator.ternary.lpl",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.arrow.lpl",
          "match": "->"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.lpl" }
          }
        }
      ]
    },
    "class-declaration": {
      "patterns": [
        {
          "match": "\\b(class)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.class.lpl" },
            "2": { "name": "entity.name.type.class.lpl" }
          }
        }
      ]
    },
    "interface-declaration": {
      "patterns": [
        {
          "match": "\\b(interface)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.class.lpl" },
            "2": { "name": "entity.name.type.interface.lpl" }
          }
        }
      ]
    }
  }
}
