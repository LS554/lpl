{
  "name": "lpl-syntax",
  "displayName": "LPL Language",
  "description": "Syntax highlighting, autocomplete, and hover documentation for the LPL programming language.",
  "version": "0.1.0",
  "author": "London Sheard",
  "publisher": "london-sheard",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:lpl"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lpl",
        "aliases": [
          "LPL",
          "lpl"
        ],
        "extensions": [
          ".lpl",
          ".lph"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lpl",
        "scopeName": "source.lpl",
        "path": "./syntaxes/lpl.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[lpl]": {
        "editor.wordBasedSuggestions": "off",
        "editor.suggest.snippetsPreventQuickSuggestions": false
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=out/extension.js",
    "watch": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=out/extension.js --watch",
    "build:lsp": "cd ../../lpl-lsp && npm install && npm run build && mkdir -p ../vscode/lpl-lang/lsp/out && cp out/server.js ../vscode/lpl-lang/lsp/out/server.js",
    "build": "npm run build:lsp && npm run compile",
    "prepackage": "npm run build",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.0.0"
  }
}
